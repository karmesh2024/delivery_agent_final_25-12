/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ai_skills {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String               @unique @db.VarChar(255)
  description        String
  type               String?              @default("webhook") @db.VarChar(50)
  input_schema       Json?                @default("{}")
  webhook_url        String?
  is_active          Boolean?             @default(true)
  created_at         DateTime?            @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at         DateTime?            @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  source             String?              @default("code")
  pipeline_id        String?              @db.Uuid
  icon               String?              @default("⚡")
  category           String?              @default("general")
  ai_skill_functions ai_skill_functions[]
  function_pipelines function_pipelines?  @relation(fields: [pipeline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([pipeline_id], map: "idx_ai_skills_pipeline")
  @@index([source], map: "idx_ai_skills_source")
  @@schema("public")
}

/// جدول الذاكرة الخاص بوكيل Zoon للاحتفاظ بالسياق، التفضيلات، والمهام عبر جلسات متعددة
model agent_memory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String
  /// 'preference', 'task', 'conversation'
  memory_type String
  content     String
  tags        String[]
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([user_id])
  @@index([memory_type])
  @@schema("public")
}

/// جدول المهام المجدولة والشرطية للذكاء الاصطناعي (مثل التقارير اليومية أو التنبيهات عند تجاوز حد معين)
model scheduled_triggers {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_name       String
  description     String?
  cron_expression String
  prompt_template String
  is_active       Boolean?  @default(true)
  last_run_at     DateTime? @db.Timestamptz(6)
  next_run_at     DateTime? @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

/// جدول إدارة شخصيات الوكيل وتوجيهاته الأساسية (System Prompts) مع دعم النسخ (Versioning)
model system_prompts {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version    Int
  content    String
  is_active  Boolean?  @default(false)
  created_by String?
  note       String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model function_pipelines {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  nodes       Json
  is_active   Boolean?    @default(true)
  created_by  String?
  created_at  DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?   @default(now()) @db.Timestamptz(6)
  ai_skills   ai_skills[]

  @@schema("public")
}

model idempotency_records {
  key        String    @id
  node_id    String
  result     Json?
  status     String?   @default("success")
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model pipeline_dead_letter_queue {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trace_id        String    @db.Uuid
  pipeline_id     String?   @db.Uuid
  steps           Json
  partial_results Json?
  failed_at_step  Int
  error_message   String
  retry_count     Int?      @default(0)
  status          String?   @default("pending")
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  resolved_at     DateTime? @db.Timestamptz(6)
  resolved_by     String?

  @@index([status], map: "idx_dlq_status")
  @@schema("public")
}

model pipeline_trace_logs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trace_id    String    @db.Uuid
  level       String
  node_id     String?
  step_index  Int?
  message     String
  data        Json?
  duration_ms Int?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([trace_id], map: "idx_trace_logs_trace_id")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ai_skill_functions {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skill_id     String    @db.Uuid
  name         String
  label        String
  description  String?
  type         String?   @default("internal")
  endpoint     String?
  input_schema Json?     @default("{}")
  is_active    Boolean?  @default(true)
  sort_order   Int?      @default(1)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
  ai_skills    ai_skills @relation(fields: [skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([skill_id, name])
  @@index([skill_id], map: "idx_skill_functions_skill")
  @@schema("public")
}

