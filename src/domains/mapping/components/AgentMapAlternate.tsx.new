// Replace date-fns formatting with native JS formatting
const formatTimeToArabic = (timestamp: string | Date) => {
  try {
    const date = new Date(timestamp);
    return new Intl.DateTimeFormat('ar', { 
      hour: '2-digit', 
      minute: '2-digit', 
      second: '2-digit',
      hour12: true
    }).format(date);
  } catch (e) {
    console.error("Error formatting time:", e);
    return "غير متوفر";
  }
}; 